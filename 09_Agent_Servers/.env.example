# LLM / embeddings (use OpenAI directly OR Vercel AI Gateway)
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
OPENAI_BASE_URL=

TAVILY_API_KEY=

# LangSmith tracing (free Developer tier works for Self-Hosted Lite)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# Self-hosted / Railway (Postgres + Redis required for production Docker)
DATABASE_URI=
REDIS_URI=

# Recommended for graphs with sync tool/RAG code
BG_JOB_ISOLATED_LOOPS=True

# Optional model overrides
OPENAI_CHAT_MODEL=openai/gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small

# Where RAG loads PDFs from (relative to this folder)
RAG_DATA_DIR=data
